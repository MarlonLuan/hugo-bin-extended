{
  "name": "hugo-bin",
  "version": "0.157.1",
  "hugoVersion": "0.160.1",
  "description": "Binary wrapper for Hugo",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MarlonLuan/hugo-bin-extended.git"
  },
  "bugs": {
    "url": "https://github.com/MarlonLuan/hugo-bin-extended/issues"
  },
  "homepage": "https://github.com/MarlonLuan/hugo-bin-extended#readme",
  "author": "MarlonLuan",
  "contributors": [
    "MarlonLuan"
  ],
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/MarlonLuan"
    }
  ],
  "keywords": [
    "binary",
    "executable",
    "hugo",
    "sass",
    "scss",
    "wrapper"
  ],
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": "./index.js"
  },
  "bin": {
    "hugo": "bin/cli.js"
  },
  "files": [
    "bin/cli.js",
    "lib/*.js",
    "index.js"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@xhmikosr/bin-wrapper": "^14.2.3",
    "package-config": "^5.0.0"
  },
  "devDependencies": {
    "@xhmikosr/bin-check": "^8.2.1",
    "c8": "^11.0.0",
    "uvu": "^0.5.6",
    "xo": "^2.0.2"
  },
  "scripts": {
    "lint": "xo",
    "fix": "xo --fix",
    "uvu": "uvu test",
    "test": "npm run lint && npm run uvu",
    "test:ci": "c8 npm run uvu",
    "postinstall": "node lib/install.js"
  }
}
